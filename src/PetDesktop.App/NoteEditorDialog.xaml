<Window x:Class="PetDesktop.App.NoteEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑便签" Width="710" Height="720" MinWidth="650" MinHeight="650"
        WindowStartupLocation="Manual" ResizeMode="NoResize"
        Background="{DynamicResource Canvas}" Foreground="{DynamicResource Text}"
        FontFamily="Microsoft YaHei UI" FontSize="13.5">
    <Window.Resources>
        <SolidColorBrush x:Key="Canvas" Color="#171717" />
        <SolidColorBrush x:Key="Panel" Color="#222222" />
        <SolidColorBrush x:Key="Input" Color="#202020" />
        <SolidColorBrush x:Key="Stroke" Color="#3A3A3A" />
        <SolidColorBrush x:Key="Text" Color="#F4F4F2" />
        <SolidColorBrush x:Key="Muted" Color="#A6A6A6" />
        <SolidColorBrush x:Key="Accent" Color="#A8C7FA" />
        <SolidColorBrush x:Key="WheelSelected" Color="#3A4A68" />
        <SolidColorBrush x:Key="WheelItem" Color="#AAAAAA" />
        <SolidColorBrush x:Key="OnAccent" Color="#FFFFFF" />
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource Text}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="frame" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="frame" Property="Opacity" Value="0.86" /></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="frame" Property="Opacity" Value="0.72" /></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Input}" />
            <Setter Property="Foreground" Value="{DynamicResource Text}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Stroke}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="CaretBrush" Value="{DynamicResource Accent}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Wheel" TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource Input}" />
            <Setter Property="Foreground" Value="{DynamicResource Text}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Stroke}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="142" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10" Padding="4">
                            <ScrollViewer Focusable="False" CanContentScroll="True" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                                <ItemsPresenter />
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                        <Setter Property="Padding" Value="8,8" />
                        <Setter Property="Foreground" Value="{DynamicResource WheelItem}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="row" Background="Transparent" CornerRadius="7" Margin="4,1">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="row" Property="Background" Value="{DynamicResource WheelSelected}" />
                                            <Setter Property="Foreground" Value="{DynamicResource OnAccent}" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource Input}" />
            <Setter Property="Foreground" Value="{DynamicResource Text}" />
        </Style>
        <Style x:Key="RepeatCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource Input}" />
            <Setter Property="Foreground" Value="{DynamicResource Text}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Stroke}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Right" Text="⌄" Foreground="{DynamicResource Muted}" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <ContentPresenter Margin="{TemplateBinding Padding}" Content="{TemplateBinding SelectionBoxItem}" VerticalAlignment="Center"/>
                                </DockPanel>
                            </Border>
                            <ToggleButton Background="Transparent" BorderThickness="0" IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True" PopupAnimation="Fade">
                                <Border Background="{DynamicResource Input}" BorderBrush="{DynamicResource Stroke}" BorderThickness="1" CornerRadius="8" Margin="0,4,0,0" MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="220"><ItemsPresenter/></ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Padding="28" Background="{DynamicResource Canvas}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid>
                <StackPanel>
                    <TextBlock Text="便签" FontSize="25" FontWeight="SemiBold" />
                    <TextBlock Text="把内容和提醒安排在同一个地方。滚动时间列即可精确到分钟。" Foreground="{StaticResource Muted}" Margin="0,5,0,0" />
                </StackPanel>
                <Button Content="×" FontSize="22" HorizontalAlignment="Right" VerticalAlignment="Top" Padding="8,0" Click="CancelClick" />
            </Grid>
            <Grid Grid.Row="1" Margin="0,26,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="270" />
                </Grid.ColumnDefinitions>
                <StackPanel Margin="0,0,24,0">
                    <TextBlock Text="内容" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,0,0,8" />
                    <TextBox x:Name="NoteTextInput" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="272" MaxLength="500" />
                    <TextBlock Text="最多 500 个字符" Foreground="{StaticResource Muted}" FontSize="11" Height="18" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,7,4,0" />
                </StackPanel>
                <Border Grid.Column="1" Background="{StaticResource Panel}" BorderBrush="{StaticResource Stroke}" BorderThickness="1" CornerRadius="14" Padding="18">
                    <StackPanel>
                        <CheckBox x:Name="ReminderEnabled" Content="在指定时间提醒我" Foreground="{DynamicResource Text}" IsChecked="True" Checked="ReminderChanged" Unchecked="ReminderChanged" />
                        <TextBlock Text="日期" Foreground="{DynamicResource Muted}" FontSize="12" Margin="0,16,0,7" />
                        <Grid>
                            <Button x:Name="DatePickerButton" MinWidth="154" HorizontalAlignment="Left" Background="{DynamicResource Input}" BorderBrush="{DynamicResource Stroke}" BorderThickness="1" Padding="11,7" HorizontalContentAlignment="Stretch" Click="OpenDatePicker">
                                <DockPanel>
                                    <TextBlock x:Name="DateDisplay" Foreground="{DynamicResource Text}" FontSize="14" VerticalAlignment="Center" />
                                    <TextBlock DockPanel.Dock="Right" Text="⌄" Foreground="{DynamicResource Muted}" FontSize="16" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </DockPanel>
                            </Button>
                            <Popup x:Name="DatePopup" Placement="Bottom" PlacementTarget="{Binding ElementName=DatePickerButton}" AllowsTransparency="True" StaysOpen="False" PopupAnimation="Fade">
                                <Border x:Name="CalendarPopupSurface" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Stroke}" BorderThickness="1" CornerRadius="12" Padding="7" Margin="0,6,0,0">
                                    <Calendar x:Name="DateCalendar" Background="{DynamicResource Panel}" Foreground="{DynamicResource Text}" BorderThickness="0" SelectedDatesChanged="DateSelected">
                                        <Calendar.Resources>
                                            <Style TargetType="CalendarDayButton">
                                                <Setter Property="Foreground" Value="{DynamicResource CalendarText}" />
                                                <Setter Property="FontWeight" Value="Normal" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="CalendarDayButton">
                                                            <Border x:Name="day" Background="Transparent" BorderBrush="Transparent" BorderThickness="1" CornerRadius="7" Margin="1">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="day" Property="Background" Value="{DynamicResource CalendarHover}" /></Trigger>
                                                                <Trigger Property="IsSelected" Value="True"><Setter TargetName="day" Property="Background" Value="{DynamicResource CalendarAccent}" /><Setter Property="Foreground" Value="{DynamicResource CalendarOnAccent}" /></Trigger>
                                                                <Trigger Property="IsToday" Value="True"><Setter TargetName="day" Property="BorderBrush" Value="{DynamicResource CalendarAccent}" /></Trigger>
                                                                <Trigger Property="IsInactive" Value="True"><Setter Property="Foreground" Value="{DynamicResource CalendarMuted}" /></Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                            <Style TargetType="CalendarButton">
                                                <Setter Property="Foreground" Value="{DynamicResource CalendarText}" />
                                                <Setter Property="FontWeight" Value="Normal" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="CalendarButton">
                                                            <Border x:Name="month" Background="Transparent" CornerRadius="7" Margin="1">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="month" Property="Background" Value="{DynamicResource CalendarHover}" /></Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Calendar.Resources>
                                    </Calendar>
                                </Border>
                            </Popup>
                        </Grid>
                        <TextBlock Text="时间" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,17,0,7" />
                        <Grid x:Name="TimeControls">
                            <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition Width="10" /><ColumnDefinition /></Grid.ColumnDefinitions>
                            <ListBox x:Name="HourInput" Style="{StaticResource Wheel}" />
                            <TextBlock Grid.Column="1" Text=":" Foreground="{StaticResource Muted}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="SemiBold" />
                            <ListBox x:Name="MinuteInput" Grid.Column="2" Style="{StaticResource Wheel}" />
                        </Grid>
                        <TextBlock Text="重复" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,17,0,7" />
                        <ComboBox x:Name="RepeatInput" Background="{DynamicResource Input}" Foreground="{DynamicResource Text}" BorderBrush="{DynamicResource Stroke}" Padding="8,6" FontWeight="SemiBold" SelectionChanged="RepeatChanged">
                            <ComboBoxItem Content="仅一次" Tag="single" />
                            <ComboBoxItem Content="每天" Tag="daily" />
                            <ComboBoxItem Content="每周" Tag="weekly" />
                            <ComboBoxItem Content="每月" Tag="monthly" />
                            <ComboBoxItem Content="每 N 天" Tag="ndays" />
                        </ComboBox>
                        <StackPanel x:Name="RepeatDaysPanel" Orientation="Horizontal" Margin="0,8,0,0" Visibility="Collapsed">
                            <TextBlock Text="间隔" Foreground="{DynamicResource Muted}" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBox x:Name="RepeatDaysInput" Width="76" Text="2" ToolTip="输入重复间隔天数" />
                            <TextBlock Text="天" Foreground="{DynamicResource Muted}" VerticalAlignment="Center" Margin="8,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
            <Grid Grid.Row="2">
                <TextBlock x:Name="ValidationMessage" Foreground="#F1A8A8" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取消" BorderBrush="#4A4A4A" BorderThickness="1" Padding="17,9" Margin="0,0,8,0" Click="CancelClick" />
                    <Button Content="保存便签" Background="#A8C7FA" Foreground="#151515" FontWeight="SemiBold" Padding="17,9" Click="SaveClick" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
