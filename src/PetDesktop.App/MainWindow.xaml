<Window x:Class="PetDesktop.App.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Pet Desktop" Width="1120" Height="720" MinWidth="960" MinHeight="640" WindowStartupLocation="CenterScreen" FontFamily="Microsoft YaHei UI" FontSize="13.5">
  <Window.Resources>
    <SolidColorBrush x:Key="AppBg" Color="#1C1C1E"/><SolidColorBrush x:Key="SidebarBg" Color="#161617"/><SolidColorBrush x:Key="Surface" Color="#2C2C2E"/><SolidColorBrush x:Key="SurfaceMuted" Color="#3A3A3C"/><SolidColorBrush x:Key="Border" Color="#3D3D40"/><SolidColorBrush x:Key="TextPrimary" Color="#F5F5F7"/><SolidColorBrush x:Key="TextSecondary" Color="#A1A1A6"/><SolidColorBrush x:Key="TextTertiary" Color="#6C6C70"/><SolidColorBrush x:Key="Primary" Color="#0A84FF"/><SolidColorBrush x:Key="OnPrimary" Color="#FFFFFF"/><SolidColorBrush x:Key="Selected" Color="#223C5B"/><SolidColorBrush x:Key="Danger" Color="#FF6B63"/>
    <Style TargetType="Button"><Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/><Setter Property="Background" Value="Transparent"/><Setter Property="BorderBrush" Value="Transparent"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="12,8"/><Setter Property="Cursor" Value="Hand"/><Setter Property="FontWeight" Value="Normal"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="frame" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="frame" Property="Opacity" Value="0.86"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter TargetName="frame" Property="Opacity" Value="0.72"/></Trigger><Trigger Property="IsEnabled" Value="False"><Setter TargetName="frame" Property="Opacity" Value="0.45"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
    <Style x:Key="NavButton" TargetType="Button"><Setter Property="HorizontalContentAlignment" Value="Left"/><Setter Property="Height" Value="38"/><Setter Property="Margin" Value="0,2,0,0"/><Setter Property="Padding" Value="12,0"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="frame" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}"><ContentPresenter VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="frame" Property="Background" Value="{DynamicResource SurfaceMuted}"/><Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
    <Style x:Key="Card" TargetType="Border"><Setter Property="Background" Value="{DynamicResource Surface}"/><Setter Property="BorderBrush" Value="{DynamicResource Border}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="12"/></Style>
    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Setter Property="Background" Value="{DynamicResource Primary}"/><Setter Property="Foreground" Value="{DynamicResource OnPrimary}"/><Setter Property="Height" Value="34"/><Setter Property="Padding" Value="15,8"/></Style>
    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Setter Property="Background" Value="{DynamicResource SurfaceMuted}"/><Setter Property="BorderBrush" Value="{DynamicResource Border}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/><Setter Property="Height" Value="34"/></Style>
    <Style TargetType="TextBox"><Setter Property="Background" Value="{DynamicResource SurfaceMuted}"/><Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/><Setter Property="BorderBrush" Value="{DynamicResource Border}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="10,7"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="TextBox"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}"><ScrollViewer x:Name="PART_ContentHost"/></Border></ControlTemplate></Setter.Value></Setter></Style>
    <Style TargetType="ComboBox"><Setter Property="Background" Value="{DynamicResource SurfaceMuted}"/><Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/><Setter Property="BorderBrush" Value="{DynamicResource Border}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="10,6"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ComboBox"><Grid><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8"><DockPanel><TextBlock DockPanel.Dock="Right" Text="⌄" Foreground="{DynamicResource TextSecondary}" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/><ContentPresenter Content="{TemplateBinding SelectionBoxItem}" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/></DockPanel></Border><ToggleButton Background="Transparent" BorderThickness="0" IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"/><Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True" PopupAnimation="Fade"><Border Background="{DynamicResource Surface}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="8" Margin="0,4,0,0" MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"><ScrollViewer MaxHeight="220"><ItemsPresenter/></ScrollViewer></Border></Popup></Grid></ControlTemplate></Setter.Value></Setter></Style>
    <Style TargetType="ComboBoxItem"><Setter Property="Background" Value="{DynamicResource Surface}"/><Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/><Setter Property="Padding" Value="10,7"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ComboBoxItem"><Border x:Name="item" Background="{TemplateBinding Background}" CornerRadius="6" Margin="3,2" Padding="{TemplateBinding Padding}"><ContentPresenter/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="item" Property="Background" Value="{DynamicResource SurfaceMuted}"/></Trigger><Trigger Property="IsSelected" Value="True"><Setter TargetName="item" Property="Background" Value="{DynamicResource Selected}"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
    <Style TargetType="ListBoxItem"><Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/><Setter Property="Padding" Value="8,7"/><Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ListBoxItem"><Border x:Name="row" Background="Transparent" CornerRadius="8" Margin="2,1" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="row" Property="Background" Value="{DynamicResource SurfaceMuted}"/></Trigger><Trigger Property="IsSelected" Value="True"><Setter TargetName="row" Property="Background" Value="{DynamicResource Selected}"/><Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
  </Window.Resources>
  <Border Background="{DynamicResource AppBg}"><Grid>
    <Grid.RowDefinitions><RowDefinition Height="44"/><RowDefinition Height="*"/></Grid.RowDefinitions>
    <Border Background="{DynamicResource SidebarBg}" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1"><Grid Margin="16,0"><TextBlock Text="PET DESKTOP" Foreground="{DynamicResource TextSecondary}" FontWeight="SemiBold" VerticalAlignment="Center"/><TextBlock Text="管理中心" Foreground="{DynamicResource TextTertiary}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/><Button x:Name="ThemeToggle" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="10,4" Click="ToggleThemeClick"/></Grid></Border>
    <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="224"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
      <Border Background="{DynamicResource SidebarBg}" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,1,0" Padding="16"><DockPanel>
        <StackPanel DockPanel.Dock="Top"><Border Style="{StaticResource Card}" Padding="12" Margin="0,0,0,24"><StackPanel><TextBlock Text="桌面伙伴" Foreground="{DynamicResource TextPrimary}" FontSize="16" FontWeight="SemiBold"/><TextBlock Text="本地陪伴与提醒" Foreground="{DynamicResource TextTertiary}" FontSize="11" Margin="0,3,0,0"/></StackPanel></Border><TextBlock Text="工作区" Foreground="{DynamicResource TextTertiary}" FontSize="11" Margin="10,0,0,6"/><Button x:Name="HomeNav" Style="{StaticResource NavButton}" Content="今天" Background="{DynamicResource Selected}" Foreground="{DynamicResource Primary}" Click="ShowHome"/><Button x:Name="NotesNav" Style="{StaticResource NavButton}" Content="便签与提醒" Click="ShowNotes"/><Button x:Name="CompanionNav" Style="{StaticResource NavButton}" Content="陪伴" Click="ShowCompanion"/></StackPanel>
        <StackPanel DockPanel.Dock="Bottom"><Separator Background="{DynamicResource Border}" Margin="0,0,0,14"/><Button x:Name="SettingsNav" Style="{StaticResource NavButton}" Content="外观与通用设置" Click="ShowSettings"/><TextBlock Text="数据只保存在此设备" Foreground="{DynamicResource TextTertiary}" FontSize="11" Margin="10,16,10,0" TextWrapping="Wrap"/></StackPanel>
      </DockPanel></Border>
      <Grid Grid.Column="1" Margin="32,28"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Grid><StackPanel><TextBlock x:Name="PageTitle" Text="今天" Foreground="{DynamicResource TextPrimary}" FontSize="24" FontWeight="SemiBold"/><TextBlock x:Name="PageSubtitle" Text="把注意力留给下一件重要的事。" Foreground="{DynamicResource TextSecondary}" Margin="0,5,0,0"/></StackPanel><Button x:Name="PrimaryAction" Style="{StaticResource PrimaryButton}" Content="新建便签" HorizontalAlignment="Right" VerticalAlignment="Center" Click="PrimaryActionClick"/></Grid>
        <Grid Grid.Row="1" Margin="0,28,0,0">
          <Grid x:Name="HomePage"><Grid.ColumnDefinitions><ColumnDefinition Width="1.25*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><StackPanel Margin="0,0,12,0"><TextBlock Text="下一件事" Foreground="{DynamicResource TextTertiary}" FontSize="12" Margin="2,0,0,8"/><Border Style="{StaticResource Card}" Padding="20"><StackPanel><TextBlock x:Name="ContentTitle" Text="暂时没有待办事项" Foreground="{DynamicResource TextPrimary}" FontSize="18" FontWeight="SemiBold"/><TextBlock x:Name="ContentDetail" Text="创建一条便签，或为它设置精确到分钟的提醒。" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,8,0,0"/><StackPanel x:Name="NoteActions" Orientation="Horizontal" Margin="0,18,0,0" Visibility="Collapsed"><Button Style="{StaticResource SecondaryButton}" Content="完成" Click="CompleteNote"/><Button Style="{StaticResource SecondaryButton}" Content="编辑" Margin="8,0,0,0" Click="EditNote"/><Button Style="{StaticResource SecondaryButton}" Content="10 分钟后" Margin="8,0,0,0" Click="SnoozeNote"/><Button Content="删除" Foreground="{DynamicResource Danger}" Margin="8,0,0,0" Click="DeleteNote"/></StackPanel></StackPanel></Border><Border Style="{StaticResource Card}" Padding="18" Margin="0,12,0,0"><StackPanel><TextBlock Text="快速入口" Foreground="{DynamicResource TextTertiary}" FontSize="12"/><Button Content="管理全部便签与提醒" Foreground="{DynamicResource Primary}" HorizontalAlignment="Left" Padding="0,10" Click="ShowNotes"/></StackPanel></Border></StackPanel><StackPanel Grid.Column="1" Margin="12,0,0,0"><Border Style="{StaticResource Card}" Padding="18"><StackPanel><TextBlock Text="陪伴进度" Foreground="{DynamicResource TextTertiary}" FontSize="12"/><TextBlock x:Name="LevelDisplay" Text="等级 1" Foreground="{DynamicResource TextPrimary}" FontFamily="Segoe UI Variable Display" FontSize="28" FontWeight="SemiBold" Margin="0,12,0,0"/><Border Background="{DynamicResource SurfaceMuted}" Height="6" CornerRadius="3" Margin="0,18,0,0"><Border Background="{DynamicResource Primary}" Width="92" HorizontalAlignment="Left" CornerRadius="3"/></Border><TextBlock x:Name="ProgressDisplay" Text="0 / 3 次成长进度" Foreground="{DynamicResource TextTertiary}" FontSize="11" Margin="0,8,0,0"/></StackPanel></Border><Border Style="{StaticResource Card}" Padding="18" Margin="0,12,0,0"><StackPanel><TextBlock Text="一句陪伴" Foreground="{DynamicResource TextTertiary}" FontSize="12"/><TextBlock x:Name="QuoteDisplay" Text="“慢一点也没关系，今天还有时间。”" Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap" Margin="0,9,0,0"/></StackPanel></Border></StackPanel></Grid>
          <Grid x:Name="NotesPage" Visibility="Collapsed"><Grid.ColumnDefinitions><ColumnDefinition Width="1.35*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border Style="{StaticResource Card}" Padding="8" Margin="0,0,12,0"><DockPanel><TextBlock DockPanel.Dock="Top" Text="全部便签" Foreground="{DynamicResource TextTertiary}" FontSize="12" Margin="10,8,10,6"/><ListBox x:Name="NotesList" Background="Transparent" BorderThickness="0" SelectionChanged="NotesSelectionChanged"/></DockPanel></Border><Border Grid.Column="1" Style="{StaticResource Card}" Padding="20" Margin="12,0,0,0"><StackPanel><TextBlock Text="提醒操作" Foreground="{DynamicResource TextTertiary}" FontSize="12"/><TextBlock Text="选中左侧便签后，可完成、编辑、稍后提醒或直接删除。" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,8,0,18"/><Button Style="{StaticResource PrimaryButton}" Content="新建便签" HorizontalAlignment="Left" Click="PrimaryActionClick"/><StackPanel Orientation="Horizontal" Margin="0,12,0,0"><Button Style="{StaticResource SecondaryButton}" Content="完成所选便签" Click="CompleteNote"/><Button Style="{StaticResource SecondaryButton}" Content="编辑" Margin="8,0,0,0" Click="EditNote"/></StackPanel><Button Style="{StaticResource SecondaryButton}" Content="10 分钟后提醒" HorizontalAlignment="Left" Margin="0,8,0,0" Click="SnoozeNote"/><Button Content="删除所选便签" Foreground="{DynamicResource Danger}" BorderBrush="{DynamicResource Danger}" BorderThickness="1" HorizontalAlignment="Left" Margin="0,16,0,0" Click="DeleteNote"/></StackPanel></Border></Grid>
          <Grid x:Name="CompanionPage" Visibility="Collapsed"><Grid.ColumnDefinitions><ColumnDefinition Width="1.2*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border Style="{StaticResource Card}" Padding="18" Margin="0,0,12,0"><DockPanel><StackPanel DockPanel.Dock="Top"><TextBlock Text="自定义短句" Foreground="{DynamicResource TextPrimary}" FontSize="16" FontWeight="SemiBold"/><TextBlock Text="短句会在点击桌宠或按设定频率时出现。" Foreground="{DynamicResource TextSecondary}" Margin="0,5,0,14"/><StackPanel Orientation="Horizontal"><TextBox x:Name="CustomQuoteInput" Width="280"/><Button Style="{StaticResource PrimaryButton}" Content="添加短句" Margin="8,0,0,0" Click="AddCustomQuoteClick"/></StackPanel><StackPanel Orientation="Horizontal" Margin="0,10,0,0"><Button Style="{StaticResource SecondaryButton}" Content="删除选中短句" Click="DeleteSelectedQuoteClick"/><Button Content="清空自定义短句" Foreground="{DynamicResource Danger}" Margin="10,0,0,0" Click="ClearCustomQuotesClick"/></StackPanel></StackPanel><ListBox x:Name="QuotesList" Background="Transparent" BorderThickness="0" Margin="0,18,0,0"/></DockPanel></Border><StackPanel Grid.Column="1" Margin="12,0,0,0"><Border Style="{StaticResource Card}" Padding="18"><StackPanel><TextBlock Text="出现频率" Foreground="{DynamicResource TextPrimary}" FontSize="16" FontWeight="SemiBold"/><TextBlock Text="设置为任意正整数分钟；点击桌宠仍可随时触发。" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,5,0,14"/><StackPanel Orientation="Horizontal"><TextBox x:Name="QuoteMinutesInput" Width="88"/><Button Style="{StaticResource SecondaryButton}" Content="保存" Margin="8,0,0,0" Click="SaveQuoteFrequencyClick"/></StackPanel></StackPanel></Border><Border Style="{StaticResource Card}" Padding="18" Margin="0,12,0,0"><StackPanel><TextBlock Text="自动成长" Foreground="{DynamicResource TextPrimary}" FontSize="16" FontWeight="SemiBold"/><TextBlock Text="桌宠每陪伴 15 分钟增加 1 点；完成普通便签增加 1 点，完成带提醒的事项增加 2 点。等级不设上限。" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,5,0,0"/></StackPanel></Border></StackPanel></Grid>
          <Grid x:Name="SettingsPage" Visibility="Collapsed"><Grid.ColumnDefinitions><ColumnDefinition Width="1.1*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border Style="{StaticResource Card}" Padding="18" Margin="0,0,12,0"><StackPanel><TextBlock Text="外观" Foreground="{DynamicResource TextPrimary}" FontSize="16" FontWeight="SemiBold"/><TextBlock Text="在浅色与深色外观间切换；桌宠与管理中心会同步更新。" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,5,0,14"/><Button Style="{StaticResource PrimaryButton}" Content="切换深浅主题" HorizontalAlignment="Left" Click="ToggleThemeClick"/><Separator Background="{DynamicResource Border}" Margin="0,20,0,18"/><TextBlock Text="全局提醒动作" Foreground="{DynamicResource TextPrimary}" FontSize="16" FontWeight="SemiBold"/><TextBlock Text="所有到期便签均触发同一个桌宠动作，不会保存到单条便签中。" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,5,0,12"/><ComboBox x:Name="ReminderActionInput" Width="180" HorizontalAlignment="Left" Background="{DynamicResource SurfaceMuted}" Foreground="{DynamicResource TextPrimary}" BorderBrush="{DynamicResource Border}" Padding="8,5" SelectionChanged="ReminderActionChanged"><ComboBoxItem Content="跳跃（默认）"/><ComboBoxItem Content="挥手"/></ComboBox></StackPanel></Border><Border Grid.Column="1" Style="{StaticResource Card}" Padding="18" Margin="12,0,0,0"><StackPanel x:Name="SettingsActions"><TextBlock Text="数据管理" Foreground="{DynamicResource TextPrimary}" FontSize="16" FontWeight="SemiBold"/><TextBlock Text="便签与成长数据可单独清除，操作不会影响宠物资源。" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,5,0,14"/><Button Content="清除便签与提醒" Foreground="{DynamicResource Danger}" HorizontalAlignment="Left" Click="ClearNotesClick"/><Button Content="重置等级进度" Foreground="{DynamicResource Danger}" HorizontalAlignment="Left" Margin="0,8,0,0" Click="ResetLevelClick"/></StackPanel></Border></Grid>
        </Grid>
      </Grid>
    </Grid>
  </Grid></Border>
</Window>
